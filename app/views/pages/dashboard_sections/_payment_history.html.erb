<div class="card shadow-sm mb-4">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Payment History</h5>
    <%= link_to "Make a Payment", new_payment_path, class: "btn btn-sm btn-primary", data: { turbo: false } %>
  </div>
  <div class="card-body">
    <% if @charges.any? %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>Date</th>
              <th>Type</th>
              <th>Description</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Receipt</th>
            </tr>
          </thead>
          <tbody>
            <% @charges.each do |payment| %>
              <tr>
                <td>
                  <% if payment.data && payment.data["created_at"] %>
                    <%= Time.at(payment.data["created_at"]).strftime("%b %d, %Y") %>
                  <% else %>
                    <%= payment.created_at.strftime("%b %d, %Y") %>
                  <% end %>
                </td>
                <td>
                  <% if payment.is_a?(Pay::Subscription) %>
                    <span class="badge bg-primary">Subscription</span>
                  <% else %>
                    <span class="badge bg-info">One-time</span>
                  <% end %>
                </td>
                <td>
                  <% if payment.is_a?(Pay::Charge) %>
                    <% if payment.metadata.present? && payment.metadata["description"].present? %>
                      <%= payment.metadata["description"] %>
                    <% else %>
                      Payment
                    <% end %>
                  <% elsif payment.is_a?(Pay::Subscription) %>
                    <%= payment.name || "Subscription" %>
                  <% end %>
                </td>
                <td>
                  <% if payment.is_a?(Pay::Subscription) %>
                    <% if payment.data && payment.data["amount"] %>
                      $<%= sprintf('%.2f', payment.data["amount"] / 100.0) %> / 
                      <%= payment.data["interval"] == "year" ? "year" : "month" %>
                    <% else %>
                      -
                    <% end %>
                  <% else %>
                    <%= number_to_currency(payment.amount / 100.0) %>
                  <% end %>
                </td>
                <td>
                  <% if payment.is_a?(Pay::Subscription) %>
                    <% if payment.status == "active" %>
                      <span class="badge bg-success">Active</span>
                    <% elsif payment.status == "canceled" %>
                      <span class="badge bg-danger">Canceled</span>
                    <% elsif payment.status == "past_due" %>
                      <span class="badge bg-warning">Past Due</span>
                    <% else %>
                      <span class="badge bg-secondary"><%= payment.status.titleize %></span>
                    <% end %>
                  <% elsif payment.respond_to?(:status) && payment.status.present? %>
                    <span class="badge bg-<%= payment.status == 'succeeded' ? 'success' : 'danger' %>">
                      <%= payment.status.titleize %>
                    </span>
                  <% else %>
                    <span class="badge bg-success">Paid</span>
                  <% end %>
                </td>
                <td>
                  <% if payment.is_a?(Pay::Subscription) %>
                    <%= link_to "Details", subscription_path(payment), class: "btn btn-sm btn-outline-primary", data: { turbo: false } %>
                  <% elsif payment.data && payment.data["receipt_url"].present? %>
                    <%= link_to "Receipt", payment.data["receipt_url"], target: "_blank", class: "btn btn-sm btn-outline-primary" %>
                  <% else %>
                    -
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5">
        <i class="bi bi-receipt mb-3" style="font-size: 3rem;"></i>
        <h5>No Payment History</h5>
        <p class="text-muted">You haven't made any payments yet.</p>
        <%= link_to "Make a Payment", new_payment_path, class: "btn btn-primary mt-2", data: { turbo: false } %>
      </div>
    <% end %>
  </div>
</div>