<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-12 col-lg-12">
      <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
          <h2 class="card-title text-center mb-0 fw-bold">Profile</h2>
        </div>
        
        <div class="card-body p-4">
          <%= form_with model: current_user, url: registration_path(current_user), method: :put, data: { turbo: false } do |f| %>
            <% if current_user.errors.any? %>
              <div class="alert alert-danger">
                <h4><%= pluralize(current_user.errors.count, "error") %> prohibited this update:</h4>
                <ul>
                  <% current_user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="row">
              <div class="col-md-3">
                <div class="card">
                  <div class="card-body">
                    <% if current_user.avatar.attached? %>
                      <%= image_tag(current_user.avatar.variant(resize_to_limit: [100, 100]), class: "img-fluid rounded-circle") %>
                    <% else %>
                      <p>No profile picture uploaded.</p>
                    <% end %>
                  </div>
                </div>
              </div>
              <div class="col-md-9">
                <div class="card">
                  <div class="card-body">
                    <h5 class="card-title">Upload Avatar</h5>
                    <%= f.label :avatar, class: "form-label" %>
                    <%= f.file_field :avatar, direct_upload: true, autofocus: true, class: "form-control" %>
                  </div>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
            </div>

            <% if current_user.pending_reconfirmation? %>
              <div class="alert alert-info">
                Currently waiting confirmation for: <%= current_user.unconfirmed_email %>
              </div>
            <% end %>

            <div class="mb-3" data-controller="trix">
              <%= f.label :bio, class: "form-label" %>
              <%= f.rich_textarea :bio, class: "form-control" %>
            </div>

            <% unless current_user.provider.present? %>
              <div class="mb-3">
                <%= f.label :password, "New password", class: "form-label" %>
                <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
                <div class="form-text text-muted">
                  Leave blank if you don't want to change it
                  <% if @minimum_password_length %>
                    <br />Minimum <%= @minimum_password_length %> characters
                  <% end %>
                </div>
              </div>

              <div class="mb-3">
                <%= f.label :password_confirmation, "Confirm new password", class: "form-label" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
              </div>

              <div class="mb-4">
                <%= f.label :current_password, class: "form-label" %>
                <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
                <div class="form-text text-muted">
                  We need your current password to confirm your changes
                </div>
              </div>
            <% end %>

            <div class="d-grid gap-2">
              <%= f.submit "Update", class: "btn btn-primary" %>
            </div>
          <% end %>

          <hr class="my-4">

          <div class="card mt-4 border-danger">
            <div class="card-header bg-danger bg-opacity-10 border-danger">
              <h3 class="card-title h5 text-danger mb-0">Delete Account</h3>
            </div>
            <div class="card-body">
              <p class="card-text">Once you delete your account, there is no going back. Please be certain.</p>
              <%= button_to "Delete my account", user_registration_path, 
                  data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                  method: :delete, 
                  class: "btn btn-outline-danger" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>