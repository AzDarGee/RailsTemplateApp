<%= turbo_frame_tag "dashboard_content" do %>
  <div class="card shadow-sm mb-4">
    <div class="card-header">
      <h5 class="mb-0">Payment History</h5>
    </div>
    <div class="card-body">
      <% if @charges.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Date</th>
                <th>Amount</th>
                <th>Description</th>
                <th>Status</th>
                <th>Receipt</th>
              </tr>
            </thead>
            <tbody>
              <% @charges.each do |charge| %>
                <tr>
                  <td>
                    <% if charge.data && charge.data["created_at"] %>
                      <%= Time.at(charge.data["created_at"]).strftime('%b %d, %Y') %>
                    <% else %>
                      <%= charge.created_at.strftime('%b %d, %Y') %>
                    <% end %>
                  </td>
                  <td><%= number_to_currency(charge.amount / 100.0) %></td>
                  <td>
                    <% if charge.respond_to?(:description) && charge.description.present? %>
                      <%= charge.description %>
                    <% elsif charge.data && charge.data["description"].present? %>
                      <%= charge.data["description"] %>
                    <% else %>
                      <% charge_id = charge.id.to_s %>
                      <%= charge_id.present? ? "Charge #{charge_id.include?('_') ? charge_id.split('_').last : charge_id}" : "Payment" %>
                    <% end %>
                  </td>
                  <td>
                    <% if charge.respond_to?(:status) && charge.status.present? %>
                      <span class="badge bg-<%= charge.status == 'succeeded' ? 'success' : 'danger' %>">
                        <%= charge.status.titleize %>
                      </span>
                    <% else %>
                      <span class="badge bg-success">Paid</span>
                    <% end %>
                  </td>
                  <td>
                    <% if charge.data && charge.data["receipt_url"].present? %>
                      <%= link_to "View Receipt", charge.data["receipt_url"], target: "_blank", class: "btn btn-sm btn-outline-secondary" %>
                    <% else %>
                      N/A
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-receipt mb-3" style="font-size: 2rem;"></i>
          <h5>No payment history yet</h5>
          <p class="text-muted">Your payment history will appear here once you make a payment</p>
        </div>
      <% end %>
    </div>
  </div>
<% end %>