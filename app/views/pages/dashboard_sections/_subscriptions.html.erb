<%= turbo_frame_tag "dashboard_content" do %>
  <div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Your Subscriptions</h5>
      <%= link_to "View Plans", pricing_path, class: "btn btn-sm btn-primary" %>
    </div>
    <div class="card-body">
      <% if @subscriptions.any? %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Plan</th>
                <th>Status</th>
                <th>Started</th>
                <th>Next Billing</th>
                <th>Amount</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @subscriptions.each do |subscription| %>
                <tr>
                  <td><%= subscription.name %></td>
                  <td>
                    <% case subscription.status %>
                    <% when 'active' %>
                      <span class="badge bg-success">Active</span>
                    <% when 'canceled' %>
                      <span class="badge bg-danger">Canceled</span>
                    <% when 'paused' %>
                      <span class="badge bg-warning">Paused</span>
                    <% when 'past_due' %>
                      <span class="badge bg-warning">Past Due</span>
                    <% else %>
                      <span class="badge bg-secondary">Inactive</span>
                    <% end %>
                  </td>
                  <td><%= subscription.created_at.strftime("%b %d, %Y") %></td>
                  <td>
                    <% if subscription.status == 'active' %>
                      <%= Time.at(subscription.current_period_end).strftime("%b %d, %Y") %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td>
                    <% if subscription.data && subscription.data["amount"] %>
                      $<%= sprintf('%.2f', subscription.data["amount"].to_f / 100) %>
                      <% if subscription.data["interval"] %>
                        / <%= subscription.data["interval"] %>
                      <% end %>
                    <% else %>
                      -
                    <% end %>
                  </td>
                  <td>
                    <%= link_to "View", subscription_path(subscription), class: "btn btn-sm btn-outline-primary" %>
                    <% if subscription.status == 'active' && !subscription.canceled? %>
                      <%= link_to "Cancel", subscription_path(subscription), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to cancel this subscription?" }, class: "btn btn-sm btn-outline-danger ms-1" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-credit-card-2-front mb-3" style="font-size: 2rem;"></i>
          <h5>You don't have any subscriptions yet</h5>
          <p class="text-muted">Subscribe to a plan to get started</p>
          <%= link_to "View Plans", pricing_path, class: "btn btn-primary mt-2" %>
        </div>
      <% end %>
    </div>
  </div> 
<% end %>